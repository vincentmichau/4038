{
  "name": "night-guards-unified",
  "version": "2.0.0",
  "description": "Night Guards System - Version Unifiée One-Shot",
  "main": "app-unified.js",
  "scripts": {
    "start": "node app-unified.js",
    "dev": "NODE_ENV=development node app-unified.js",
    "test": "NODE_ENV=test node app-unified.js",
    "init-db": "mysql -u $DB_USER -p$DB_PASSWORD $DB_NAME < database/complete-schema.sql",
    "setup": "npm install && npm run init-db",
    "health": "curl -f http://localhost:3000/health || exit 1",
    "logs": "tail -f logs/app.log",
    "backup": "mysqldump -u $DB_USER -p$DB_PASSWORD $DB_NAME > backup/backup_$(date +%Y%m%d_%H%M%S).sql",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "security-check": "npm audit",
    "performance-test": "artillery run tests/performance.yml",
    "docker-build": "docker build -t night-guards:unified .",
    "docker-run": "docker run -p 3000:3000 --env-file .env night-guards:unified"
  },
  "keywords": [
    "security",
    "reporting",
    "tickets",
    "night-guards",
    "surveillance",
    "pdf",
    "authentication",
    "nodejs",
    "express"
  ],
  "author": "Night Guards Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "puppeteer": "^21.6.1",
    "qrcode": "^1.5.3",
    "nodemailer": "^6.9.7",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "express-validator": "^7.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "artillery": "^2.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run security-check && npm test"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/night-guards/unified-system.git"
  },
  "bugs": {
    "url": "https://github.com/night-guards/unified-system/issues"
  },
  "homepage": "https://github.com/night-guards/unified-system#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/night-guards"
  }
}
