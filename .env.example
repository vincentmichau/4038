# =============================================
# NIGHT GUARDS SYSTEM - VERSION UNIFIÉE
# Configuration Environment - One-Shot Deployment
# =============================================

# --- Base de Données ---
DB_HOST=localhost
DB_USER=nightguards
DB_PASSWORD=secure_password_2024
DB_NAME=nightguards_db
DB_PORT=3306
DB_SSL=false

# --- Sécurité ---
JWT_SECRET=your-super-secret-jwt-key-2024-change-this-in-production
QR_CODE_SECRET=your-super-secret-qr-key-2024-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-2024
BCRYPT_ROUNDS=12

# --- Application ---
PORT=3000
NODE_ENV=development
API_VERSION=v2
BASE_URL=http://localhost:3000

# --- Email (Optionnel) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@nightguards.com

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
CREATE_RATE_LIMIT_MAX=10

# --- Fichiers ---
UPLOAD_PATH=./uploads
REPORTS_PATH=./reports
TEMP_PATH=./temp
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,txt

# --- Sessions ---
SESSION_TIMEOUT=86400000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800000

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/app.log
ERROR_LOG_FILE=./logs/error.log

# --- Monitoring ---
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true

# --- Docker ---
COMPOSE_PROJECT_NAME=nightguards
HTTP_PORT=80
HTTPS_PORT=443
DB_PORT=3306
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# --- Docker Secrets ---
MYSQL_ROOT_PASSWORD=super_root_password_2024
MYSQL_PASSWORD=secure_password_2024
REDIS_PASSWORD=redis_password_2024
GRAFANA_PASSWORD=admin123

# --- Sécurité Avancée ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
HELMET_ENABLED=true
CORS_ENABLED=true
COMPRESSION_ENABLED=true

# --- Développement ---
DEBUG=false
TEST_DATABASE=nightguards_test
MOCK_EMAIL=false
SKIP_SSL_VERIFICATION=false

# --- Backup ---
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# --- Performance ---
CLUSTER_MODE=false
WORKERS=0
CACHE_TTL=3600

# --- Integration ---
COMBO_API_URL=https://api.combo.hr
COMBO_API_KEY=your-combo-api-key
WEBHOOK_SECRET=webhook-secret-2024
