{
  "name": "nightguards-reporting",
  "version": "1.0.0",
  "description": "Application de reporting pour veilleurs de nuit multi-sites et multi-clients",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "test": "jest",
    "secure:audit": "npm audit",
    "secure:check": "npm ls --depth=0"
  },
  "keywords": ["reporting", "veille", "securité", "nodejs", "express", "react"],
  "author": "Night Guards Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.1",
    "mysql2": "^3.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "multer": "^2.1.1",
    "puppeteer": "^23.10.4",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "nodemailer": "^8.0.6",
    "express-session": "^1.18.1",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.7",
    "compression": "^1.7.5",
    "morgan": "^1.10.0",
    "winston": "^3.17.0",
    "joi": "^17.13.3",
    "argon2": "^0.41.1",
    "uuid": "^14.0.0",
    "moment": "^2.30.1",
    "ical-generator": "^5.0.0",
    "axios": "^1.7.9",
    "sharp": "^0.33.5",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-security": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
